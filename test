#!/usr/bin/env bash
set -u

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
EXAMPLES_DIR="$ROOT/examples"
OUTPUT_DIR="$EXAMPLES_DIR/output"
UPDATE=0
ARC=0
SINGLE_EXAMPLE=""

usage() {
  cat <<USAGE
Usage:
  ./test [--update] [example]
  ./test --arc example

Runs Go examples in examples/, reading examples/input/*.json where used,
compares stdout with examples/output/*.md, and prints OK/FAIL with timing.

Arguments:
  example    optional example stem, such as bmi or examples/bmi.go

Options:
  --update   regenerate examples/output/*.md from the current program output
  --arc      print the complete ARC report for one example and do not compare
  -h, --help show this help
USAGE
}

normalize_example_name() {
  local name=$1
  name=${name#examples/}
  name=${name%.go}
  printf '%s' "$name"
}

while [ $# -gt 0 ]; do
  case "$1" in
    --update)
      UPDATE=1
      ;;
    --arc)
      ARC=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      echo "Use ./test --help" >&2
      exit 2
      ;;
    *)
      if [ -n "$SINGLE_EXAMPLE" ]; then
        echo "Only one example can be selected" >&2
        echo "Use ./test --help" >&2
        exit 2
      fi
      SINGLE_EXAMPLE=$(normalize_example_name "$1")
      ;;
  esac
  shift
done

for arg in "$@"; do
  if [ -n "$SINGLE_EXAMPLE" ]; then
    echo "Only one example can be selected" >&2
    echo "Use ./test --help" >&2
    exit 2
  fi
  SINGLE_EXAMPLE=$(normalize_example_name "$arg")
done

if [ "$ARC" -eq 1 ] && [ -z "$SINGLE_EXAMPLE" ]; then
  echo "--arc requires an example name, for example: ./test --arc bmi" >&2
  exit 2
fi

if [ "$ARC" -eq 1 ] && [ "$UPDATE" -eq 1 ]; then
  echo "--arc only prints output; combine an example with --update without --arc to refresh a snapshot" >&2
  exit 2
fi

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && command -v tput >/dev/null 2>&1; then
  GREEN=$(tput setaf 2 || true)
  RED=$(tput setaf 1 || true)
  RESET=$(tput sgr0 || true)
else
  GREEN=""
  RED=""
  RESET=""
fi

ok() { printf '%sOK%s' "$GREEN" "$RESET"; }
fail() { printf '%sFAIL%s' "$RED" "$RESET"; }

if ! command -v go >/dev/null 2>&1; then
  printf '%s go toolchain not found\n' "$(fail)" >&2
  exit 127
fi

mkdir -p "$OUTPUT_DIR"
TMPDIR=$(mktemp -d "${TMPDIR:-/tmp}/see-test.XXXXXX")
trap 'rm -rf "$TMPDIR"' EXIT

if ! go build -o "$TMPDIR/see-build-output" "$ROOT/tools/build_output.go"; then
  printf '%s could not build Go output combiner\n' "$(fail)" >&2
  exit 1
fi

if ! (cd "$ROOT/examples/checks" && go build -o "$TMPDIR/see-checks" .); then
  printf '%s could not build isolated Go checker\n' "$(fail)" >&2
  exit 1
fi

now_ms() {
  local raw
  raw=$(date +%s%N 2>/dev/null || true)
  case "$raw" in
    *[!0-9]*|"") echo $(( $(date +%s) * 1000 )) ;;
    *) echo $(( raw / 1000000 )) ;;
  esac
}

format_ms() {
  local ms=$1
  printf '%d.%03ds' $((ms / 1000)) $((ms % 1000))
}

normalize() {
  sed -E \
    -e 's/[[:space:]]+$//' \
    -e 's/^[[:space:]]*-[[:space:]]+//' \
    -e 's/^platform : go[0-9][^[:space:]]* [^[:space:]]+\/[^[:space:]]+$/platform : <go-version> <os>\/<arch>/'
}

markdown_hardbreaks() {
  awk '{
    sub(/[ \t]+$/, "")
    sub(/^[ \t]*-[ \t]+/, "")
    if ($0 == "") print ""; else print $0 "  "
  }'
}

run_example() {
  local file=$1
  local name=${file%.go}
  local expected="$OUTPUT_DIR/$name.md"
  local raw="$TMPDIR/$name.go.md"
  local actual="$TMPDIR/$name.md"
  local actual_norm="$TMPDIR/$name.actual.norm"
  local expected_norm="$TMPDIR/$name.expected.norm"
  local diff_file="$TMPDIR/$name.diff"

  local start end elapsed_ms status phase
  start=$(now_ms)

  phase="go"
  if (cd "$ROOT" && go run "./examples/$file") > "$raw" 2>&1; then
    phase="go-check"
    if SEE_CHECKER="$TMPDIR/see-checks" "$TMPDIR/see-build-output" "$name" "$raw" > "$actual" 2>&1; then
      status=0
    else
      status=$?
    fi
  else
    status=$?
    cp "$raw" "$actual"
  fi

  end=$(now_ms)
  elapsed_ms=$(( end - start ))
  total_ms=$(( total_ms + elapsed_ms ))

  if [ $status -ne 0 ] && [ "$phase" = "go-check" ]; then
    printf '%s %-*s %6sms Go Check failed\n' "$(fail)" "$name_width" "$name" "$elapsed_ms"
    sed 's/^/  /' "$actual"
    return 1
  fi

  if [ $UPDATE -eq 1 ] && [ $status -eq 0 ]; then
    markdown_hardbreaks < "$actual" > "$expected"
    printf '%s   %-*s %6sms updated\n' "$(ok)" "$name_width" "$name" "$elapsed_ms"
    return 0
  fi

  if [ $status -ne 0 ]; then
    printf '%s %-*s %6sms run failed\n' "$(fail)" "$name_width" "$name" "$elapsed_ms"
    sed 's/^/  /' "$actual"
    return 1
  fi

  if [ ! -f "$expected" ]; then
    printf '%s %-*s %6sms missing %s\n' "$(fail)" "$name_width" "$name" "$elapsed_ms" "examples/output/$name.md"
    return 1
  fi

  normalize < "$actual" > "$actual_norm"
  normalize < "$expected" > "$expected_norm"

  if diff -u "$expected_norm" "$actual_norm" > "$diff_file"; then
    printf '%s   %-*s %6sms\n' "$(ok)" "$name_width" "$name" "$elapsed_ms"
    return 0
  fi

  printf '%s %-*s %6sms output differs\n' "$(fail)" "$name_width" "$name" "$elapsed_ms"
  sed 's/^/  /' "$diff_file"
  return 1
}

run_arc_example() {
  local name=$1
  local file="$name.go"
  local raw="$TMPDIR/$name.go.md"

  if ! (cd "$ROOT" && go run "./examples/$file") > "$raw" 2>&1; then
    printf '%s %s run failed\n' "$(fail)" "$name" >&2
    sed 's/^/  /' "$raw" >&2
    return 1
  fi

  SEE_CHECKER="$TMPDIR/see-checks" "$TMPDIR/see-build-output" "$name" "$raw"
}

failures=0
count=0
total_ms=0
name_width=28

mapfile -t example_files < <(find "$EXAMPLES_DIR" -maxdepth 1 -type f -name '*.go' -print | sed 's#^.*/##' | sort)

if [ -n "$SINGLE_EXAMPLE" ]; then
  selected_file="$SINGLE_EXAMPLE.go"
  if [ ! -f "$EXAMPLES_DIR/$selected_file" ]; then
    printf '%s unknown example: %s\n' "$(fail)" "$SINGLE_EXAMPLE" >&2
    exit 2
  fi
  example_files=("$selected_file")
fi

for file in "${example_files[@]}"; do
  name=${file%.go}
  if [ ${#name} -gt "$name_width" ]; then
    name_width=${#name}
  fi
done

if [ "$ARC" -eq 1 ]; then
  run_arc_example "$SINGLE_EXAMPLE"
  exit $?
fi

for file in "${example_files[@]}"; do
  count=$((count + 1))
  if ! run_example "$file"; then
    failures=$((failures + 1))
  fi
done

if [ "$count" -eq 0 ]; then
  printf '%s no Go examples found in examples/\n' "$(fail)" >&2
  exit 1
fi

printf 'Total time: %s (%sms).\n' "$(format_ms "$total_ms")" "$total_ms"

if [ "$failures" -eq 0 ]; then
  printf 'All %s example(s) %s.\n' "$count" "$(ok)"
  exit 0
fi

printf '%s of %s example(s) failed.\n' "$failures" "$count"
exit 1
