      ":Need_NoSharingWithoutConsent": {
        "ID": ":Need_NoSharingWithoutConsent",
        "Importance": 12,
        "MinNoticeDays": 0,
        "Description": "No data sharing without explicit consent."
      }
    }
  },
  "Agreement": {
    "ID": ":Agreement1",
    "Title": "Example Agreement",
    "Policy": {
      "ID": ":Policy1",
      "Permissions": {
        ":PermChangeTerms": {
          "ID": ":PermChangeTerms",
          "Assigner": ":Provider",
          "Assignee": ":ConsumerExample",
          "Action": "tosl:changeTerms",
          "Target": ":AgreementText",
          "ClauseID": ":ClauseC2",
          "Duties": [
            {
              "Action": "odrl:inform",
              "Constraints": [
                {
                  "LeftOperand": "tosl:noticeDays",
                  "Operator": "odrl:gteq",
                  "RightOperand": {
                    "Int": 3,
                    "Bool": false,
                    "Kind": "int"
                  }
                }
              ]
            }
          ],
          "Constraints": null
        },
        ":PermDeleteAccount": {
          "ID": ":PermDeleteAccount",
          "Assigner": ":Provider",
          "Assignee": ":ConsumerExample",
          "Action": "tosl:removeAccount",
          "Target": ":UserAccount",
          "ClauseID": ":ClauseC1",
          "Duties": null,
          "Constraints": null
